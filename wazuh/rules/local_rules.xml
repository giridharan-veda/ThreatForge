<!-- Example -->
<group name="local,syslog,sshd,">
  <!--
  Dec 10 01:02:02 host sshd[1234]: Failed none for root from 1.1.1.1 port 1066 ssh2
  -->
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>
</group>

<!--
  Custom IoT Attack Chain detection rules.
  Matches the JSON schema written by the Node-RED events.log:
  endpoint, method, status, large_response, pin_attempt.

  Rule IDs 100100-100200 reserved for local/custom rules per Wazuh convention.

  NOTE: "status" is a reserved/static field name in Wazuh's rule schema.
  Do NOT use <field name="status">...</field> - it will fail to load with
  "Field 'status' is static." Use <regex>"status":"value"</regex> instead,
  matched against the raw decoded log line.
-->
<group name="iot_attack_chain,">

  <rule id="100100" level="7">
    <decoded_as>json</decoded_as>
    <field name="endpoint">^/api/devices$</field>
    <field name="method">^GET$</field>
    <description>IoT Device Discovery (Reconnaissance) via Node-RED endpoint</description>
    <mitre>
      <id>T1046</id>
    </mitre>
    <group>recon,iot_attack,</group>
  </rule>

  <rule id="100110" level="10">
    <decoded_as>json</decoded_as>
    <field name="endpoint">^/api/camera/snapshot$</field>
    <field name="large_response">^true$</field>
    <description>IoT Camera Snapshot Exfiltration (response &gt;10KB)</description>
    <mitre>
      <id>T1005</id>
    </mitre>
    <group>exfiltration,iot_attack,</group>
  </rule>

  <rule id="100120" level="12">
    <decoded_as>json</decoded_as>
    <field name="endpoint">^/api/lock/unlock$</field>
    <regex>"status":"impact_success"</regex>
    <description>IoT Smart Lock Unauthorized Unlock (correct PIN used)</description>
    <mitre>
      <id>T1499</id>
    </mitre>
    <group>impact,iot_attack,</group>
  </rule>

  <rule id="100121" level="5">
    <decoded_as>json</decoded_as>
    <field name="endpoint">^/api/lock/unlock$</field>
    <regex>"status":"impact_failure"</regex>
    <description>IoT Smart Lock Failed Unlock Attempt (incorrect PIN)</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>impact,iot_attack,</group>
  </rule>

  <rule id="100130" level="9">
    <decoded_as>json</decoded_as>
    <field name="endpoint">^mqtt:home/bulb/command$</field>
    <field name="method">^PUBLISH$</field>
    <description>IoT Smart Bulb Device Manipulation via MQTT</description>
    <mitre>
      <id>T1498</id>
    </mitre>
    <group>impact,iot_attack,</group>
  </rule>

  <!--
    Rule 100200 (Lateral Movement via SSH) intentionally NOT implemented yet.
    It should extend Wazuh's BUILT-IN sshd authentication-success rule via
    <if_sid>, not the JSON decoder, since that event comes from auth.log,
    not Node-RED. Find the correct parent rule ID for your Wazuh version
    with:
      docker exec single-node-wazuh.manager-1 grep -A3 "Successful login" \
        /var/ossec/ruleset/rules/0095-sshd_rules.xml
  -->

</group>
